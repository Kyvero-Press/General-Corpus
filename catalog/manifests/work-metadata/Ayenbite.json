  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "A Kentish Middle English guide to conscience and moral life, translated by Dan Michel of Northgate from Laurent d'Orleans's French Somme le Roi. It organizes instruction around the commandments and creed, the seven deadly sins and corresponding virtues, confession and penance, prayer, almsgiving, chastity, sobriety, and the gifts of the Holy Spirit.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:ayenbite-xml",
        "evidence:ayenbite-folger"
      ]
    },
    {
      "id": "summary:scope",
      "type": "scope_note",
      "value": "The work survives uniquely in Arundel MS 57, apparently in Dan Michel's own hand. The General Corpus text represents Gradon's 1965 corrected reissue of Morris's 1866 transcription and must not be treated as a diplomatic transcription of the manuscript.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:ayenbite-arundel57",
        "evidence:ayenbite-xml",
        "evidence:ayenbite-gradon-scan"
      ]
    }
  ],

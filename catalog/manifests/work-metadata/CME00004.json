  "summaries": [
    {
      "id": "summary:contents",
      "type": "contents_note",
      "value": "A nineteenth-century serial edition of nine Middle English verse units: Alphabetical Praise of Women; two versions of A Peniworth of Witt/How a Merchant Betrayed His Wife; two Auchinleck fragments of King Richard; a tail-rhyme Assumption of the Virgin; On the Seven Deadly Sins; The Paternoster; a verse rendering of Psalm 50 called Dauid þe King; The Four Foes of Mankind; and parallel Auchinleck and Vernon texts of The King of Tars with Simeon variants.",
      "language": "eng",
      "scope": {"kind": "whole"},
      "evidence_ids": ["evidence:umich-item", "evidence:xml", "evidence:source-articles"]
    },
    {
      "id": "summary:encoding-scope",
      "type": "cataloging_note",
      "value": "CME00004 selects the edited Middle English texts and much of their local apparatus but omits substantial article introductions and discussions. It also serializes the two parallel King of Tars columns as consecutive XML version divisions, so its ten top-level DIV1 elements do not equal ten independent numbered installments.",
      "language": "eng",
      "scope": {"kind": "whole"},
      "evidence_ids": ["evidence:xml", "evidence:xml-structure", "evidence:source-articles"]
    }
  ],
  "extent": {
    "numbered_items": 12,
    "sections": 10,
    "prose_only_items": 0,
    "verse_only_items": 12,
    "mixed_items": 0,
    "verse_groups": 388,
    "verse_lines": 5159,
    "description": "Nine numbered source installments contain twelve separately counted verse items or versions and are represented by ten top-level XML DIV1 elements: installment II's two versions are split into separate DIV1 elements, installment III comprises two fragments within one DIV1, and installment IX contains two version divisions. The repository XML has 5,159 L elements, 388 LG elements, 102 PB elements, and 484 NOTE elements. These are encoding metrics: L includes four heading lines in the Vernon King of Tars and does not establish canonical line totals; editorial prose occurs outside the verse-item count.",
    "evidence_ids": ["evidence:xml-structure"]
  },

  "cataloging_subject": {
    "id": "work:CME00026",
    "unit_type": "edited_selection",
    "label": "The Thornton Romances",
    "scope_note": "The U-M/General Corpus edition-level selection encoded from James Orchard Halliwell's 1844 Camden Society volume: its title-page content and four complete verse texts on printed pp. 1-256, Sir Perceval of Galles, Sir Isumbras, Sir Eglamour of Artois, and Sir Degrevant. The selection excludes the council list, Halliwell's introduction and manuscript descriptions on pp. v-l, his essay on terminal contractions on pp. li-lvi, notes beginning on p. 257, and remaining volume matter. It is neither one medieval work, one manuscript, the complete 1844 publication, the U-M encoding, nor the checked-in XML artifact."
  },

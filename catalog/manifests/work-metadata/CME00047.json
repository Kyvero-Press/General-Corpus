  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Fowler's second Durham account-roll volume calendars and selectively transcribes records of the communar, terrar, stock-keeper or instaurar, supervisor of the prior's horses, prior's marescalcia, sacrist, feretrar, and bursar. The documents preserve detailed evidence for monastic finance, estates, rents, debts, livestock, wool, horses, courts, church fabric, books, vestments, relics, St Cuthbert's shrine, offerings, prices, labor, travel, weights and measures, and material culture from 1278 to 1538.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:cme00047-fowler-volume2",
        "evidence:cme00047-fowler-volume3",
        "evidence:cme00047-durham-catalog"
      ]
    },
    {
      "id": "summary:contents",
      "type": "contents_note",
      "value": "The encoded body has eight edition-defined sections: Communar, 23 DIV2 items on pp. 285–298; Terrar, 22 on pp. 299–308; Instaurar and stock, 17 on pp. 309–322; Supervisor Equicii, one on pp. 323–325; Marescalcia Prioris, 25 on pp. 326–371; Sacrist, 87 on pp. 372–419; Feretrar, 103 on pp. 420–483; and Bursar, 121 on pp. 484–576. The XML includes the edition title page but omits the society preliminaries, council resolution, preface, and contents.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:cme00047-structure",
        "evidence:cme00047-fowler-volume2"
      ]
    },
    {
      "id": "summary:cataloging-scope",
      "type": "scope_note",
      "value": "The 399 XML DIV2 containers represent Fowler's editorial sequence, not a physical-document inventory. Current official catalogues link 351 separate public IIIF objects, 85 exact office-account entries without IIIF, eleven stock/livestock records without IIIF, and one supervisor equicii charter to volume II. The twenty-five Marescalcia source identities remain unresolved; duplicate copies, fragments, schedules, and rejoined records require a many-to-many crosswalk.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:cme00047-structure",
        "evidence:cme00047-durham-catalog",
        "evidence:cme00047-durham-iiif"
      ]
    }
  ],

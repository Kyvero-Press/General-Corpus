  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "An anonymous early-fifteenth-century Middle English devotional compilation adapted from Heinrich Seuse's Latin Horologium sapientiae. A clerical translator addresses a spiritual daughter, explains that he omits material unsuited to her and other devout readers, rearranges and renders the sense rather than the words of the Latin, and organizes the result as seven points corresponding to the seven gifts of the Holy Spirit. The dialogue of Wisdom and the Disciple treats divine love, Christ's Passion, adversity, spiritual life, dying, the Eucharist, worship, and spiritual marriage.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-schultze"
      ]
    },
    {
      "id": "summary:transmission",
      "type": "cataloging_note",
      "value": "Modern scholarship records six complete manuscript copies, two near-complete copies, six physical manuscripts containing excerpts, and Caxton's 1491 print. Horstmann's 1888 edition and CME00059 derive directly from Bodleian MS Douce 114, not from a conflation of the complete witness tradition. The English work is distinct from the complete twenty-four-chapter Latin Horologium.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-schultze",
        "evidence:metadata-horstmann",
        "evidence:metadata-oxford"
      ]
    }
  ],
  "extent": {
    "numbered_items": 7,
    "sections": 9,
    "prose_only_items": 7,
    "verse_only_items": 0,
    "mixed_items": 0,
    "verse_groups": 0,
    "verse_lines": 0,
    "description": "Seven numbered prose points preceded by a table of contents and translator's preface. In the CME encoding the proem is not a separate DIV2 but begins within chapter 1; the explicit and Latin prayer occur within chapter 7. Encoding metrics: 10 DIV2 elements including Horstmann's editorial introduction, 127 P elements, 67 PB elements, 323 NOTE elements, and no L or LG elements.",

  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Thirty-three anonymous Middle English courtly lyrics explore service to a lady, separation, hope and despair, Fortune, mercy, fidelity, complaint, and poetic petition. MacCracken grouped twenty poems from the Fairfax Sequence with nine English poems transmitted in Charles d'Orléans's manuscript circle, two Royal manuscript lyrics, and two poems he judged stylistically similar. His proposed attribution to William de la Pole remains a historical hypothesis rather than a settled authorship.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-maccracken",
        "evidence:metadata-neilly"
      ]
    }
  ],

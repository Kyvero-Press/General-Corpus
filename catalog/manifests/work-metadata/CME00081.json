  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Joseph Hall's 1895 selection of anonymous Middle English verse from Cotton MS Galba E IX juxtaposes a moral poem on worldly transience, the personified-money satire Sir Peny, and two Passion lyrics in which Christ appeals from the Cross to the sinner. Hall numbered the final two lyrics as one third piece beneath the heading 'Popule meus, quid feci tibi?' and linked them with two separate Latin couplets; modern DIMEV records establish the four-work boundary retained here.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-hall",
        "evidence:metadata-xml",
        "evidence:metadata-dimev"
      ]
    },
    {
      "id": "summary:contents",
      "type": "contents_note",
      "value": "Three Hall-numbered divisions on printed pp. 201-209 contain 275 encoded verse lines: 94 Middle English lines in item I; 123 Middle English lines in item II; and 58 lines in item III, comprising four Latin framing lines and 54 Middle English lines. Intellectually, item III contains an 18-line appeal of Christ and a 36-line poem on Christ's mercy.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-computation",
        "evidence:metadata-xml",
        "evidence:metadata-dimev"
      ]
    }
  ],

  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Holthausen’s encoded selection presents two anonymous Middle English medical poems from KB X 90. “Gereimte Heilkunde” is a sequence of sixty-four rubricated remedy sections treating ailments and injuries; Holthausen incorporates a thirty-six-line receipt passage displaced after the herbal in the manuscript. “Heilkräuterlehre” begins with a six-line prologue and treats twenty-four named plants in 965 textual lines, giving medicinal, ritual, protective, and prognostic uses. A German afterword records additional readings and corrections.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-holthausen",
        "evidence:metadata-dimev"
      ]
    },
    {
      "id": "summary:scope",
      "type": "scope_note",
      "value": "CME00098 begins at printed p. 295, not p. 293. It contains 496 encoded verse-line elements for the receipt collection, 966 for the herbal, and two German prose paragraphs on p. 331. The herbal’s raw XML count is one greater than Holthausen’s and DIMEV’s 965-line textual lineation because a dotted lacuna row is encoded as L. The first poem’s 496 lines consist of the 460-line main run plus a 36-line displaced continuation from X 90 pp. 78–80.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-holthausen",
        "evidence:metadata-stephens"
      ]
    }
  ],

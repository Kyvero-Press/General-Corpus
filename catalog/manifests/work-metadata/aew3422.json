  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Fortescue contrasts absolute regal dominion with England's political-and-regal monarchy, then develops practical proposals for stable Crown revenue, protection of a prosperous commons, restraint of over-mighty subjects, a standing royal council, responsible officeholding, and disciplined royal grants.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-plummer"
      ]
    },
    {
      "id": "summary:contents",
      "type": "contents_note",
      "value": "Twenty numbered prose chapters: Chapters I-III establish constitutional distinctions; IV-XIV examine French and English finance, poverty, taxation, resumption, and Crown endowment; XV-XX address the royal council, appointments, pensions, and patents of gift.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-structure",
        "evidence:metadata-plummer"
      ]
    },
    {
      "id": "summary:encoding-scope",
      "type": "scope_note",
      "value": "The U-M XML verbally represents the carrier title page and Plummer's work text on printed pages 109-157. Its 412 PB milestones map the whole scanned carrier, but omitted front and back matter are not transcribed content and the retained title page is not an intrinsic chapter.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-structure"
      ]

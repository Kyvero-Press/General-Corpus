  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "A Middle English dream-vision pilgrimage through personified moral and spiritual instruction, translated and adaptively reshaped from Guillaume de Deguileville's 1355 second recension. The verse-dominant work follows the pilgrim's encounters on the way toward salvation and includes sustained Latin poems, Marian devotion, a prose consolation with a four-stanza prayer, Chaucer's ABC, and Deguileville's name acrostic.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:ajt8111-pinned-xml",
        "evidence:lineage-eets",
        "evidence:lineage-embedded"
      ]
    },
    {
      "id": "summary:scope",
      "type": "scope_note",
      "value": "The work boundary is EETS text pages 1-665. Locock's introduction, notes, glossary, indexes, omitted front and back matter, publisher notices, and the physical U-M binding are transmission or carrier layers, not additional intellectual items. The internal poems and prose tract remain mutually exclusive parts of one mixed work.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:ajt8111-pinned-xml",
        "evidence:lineage-eets",
        "evidence:lineage-digital"
      ]
    },
    {
      "id": "summary:counting",
      "type": "cataloging_note",
      "value": "The 25,421-line total is 26,346 XML L elements minus 188 note-nested rows, 727 prose-scope rows outside the prayer, and ten separately excluded paratext, rubric, or non-text rows. The embedded prayer contributes four eight-line stanzas at node 3.3.7.6. All content parts have null item_count and zero item-form metrics because the aggregate owns the single mixed item.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:ajt8111-structure-audit"
      ]
    }
  ],

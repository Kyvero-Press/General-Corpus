        "evidence:metadata-structure-audit",
        "evidence:metadata-umich-item"
      ]
    },
    {
      "id": "summary:piers",
      "type": "abstract",
      "value": "Piers Plowman is an expansive alliterative dream vision and allegorical estates satire concerned with Christian truth, labor, poverty, clerical conduct, penance, salvation, and just social order. The electronic item presents its A, B, and C recensions as version streams of one work.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:piers-plowman"
        ]
      },
      "evidence_ids": [
        "evidence:metadata-linked-ppea",
        "evidence:metadata-repo-xml"
      ]
    },
    {
      "id": "summary:political-poems",
      "type": "abstract",
      "value": "Richard the Redeless critiques Richard II's kingship and court around the deposition crisis of 1399. The Crowned King is a short early-fifteenth-century alliterative counsel poem on kingship and governance. Both are anonymous and remain separate from Langland responsibility.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:richard-redeless",
          "part:crowned-king"
        ]
      },
      "evidence_ids": [
        "evidence:metadata-linked-mets",
        "evidence:metadata-linked-mairey",
        "evidence:metadata-linked-skeat"
      ]
    }
  ],

  "summaries": [
    {
      "id": "summary:bau1376-abstract",
      "type": "abstract",
      "value": "An anonymous Middle English didactic religious poem that moves from human wretchedness and worldly instability through death, purgatory, the Last Judgment, and hell to the joys of heaven. Its entre, seven parts, and epilogue combine pastoral instruction, moral theology, eschatology, and devotional exhortation in rhymed four-stress couplets.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:mets-morey-introduction",
        "evidence:repo-xml"
      ]
    },
    {
      "id": "summary:bau1376-boundary",
      "type": "scope_note",
      "value": "The metadata describes the anonymous medieval work. Morris's eclectic edition, its table of contents copied from Garrett MS 138, the U-M OCR, scans, and physical witnesses are separate lineage layers.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [

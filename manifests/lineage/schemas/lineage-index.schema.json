{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "General Corpus lineage-manifest index",
  "description": "Discovery index for the per-work lineage manifests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "generated",
    "coverage",
    "items"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated": {
      "type": "string",
      "format": "date"
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "manifest_count",
        "notes"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "incremental",
            "complete"
          ]
        },
        "manifest_count": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "work_id",
          "title",
          "manifest",
          "repository_paths",
          "external_identifiers",
          "record_status",
          "last_reviewed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^lineage:[^ ]+$"
          },
          "work_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "manifest": {
            "type": "string",
            "pattern": "^works/[^/]+\\.json$"
          },
          "repository_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "external_identifiers": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "scheme",
                "value"
              ],
              "properties": {
                "scheme": {
                  "type": "string",
                  "minLength": 1
                },
                "value": {
                  "type": "string",
                  "minLength": 1
                },
                "uri": {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https?://"
                }
              }
            }
          },
          "record_status": {
            "enum": [
              "draft",
              "partial",
              "reviewed",
              "deprecated"
            ]
          },
          "last_reviewed": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}

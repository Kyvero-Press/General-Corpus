{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyvero.press/schemas/general-corpus/publication-set-1.0.0.json",
  "title": "General Corpus viewer publication set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "snapshot_date",
    "description",
    "item_count",
    "items"
  ],
  "properties": {
    "$schema": { "const": "schemas/publication-set.schema.json" },
    "schema_version": { "const": "1.0.0" },
    "snapshot_date": { "type": "string", "format": "date" },
    "description": { "type": "string", "minLength": 1 },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["work_id", "filename", "sha256", "bytes", "pages"],
        "properties": {
          "work_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+\\-]*$"
          },
          "filename": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+\\-]*\\.pdf$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": { "type": "integer", "minimum": 1 },
          "pages": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}

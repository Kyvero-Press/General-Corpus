  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "This encoded selection juxtaposes two Lydgate poems designed or interpreted for visual, civic, or performative display. The Legend of St George narrates the dragon episode, conversion, persecution, and martyrdom in thirty-five rhyme-royal stanzas. Of the Sodein Fal presents seven recent rulers or nobles as examples of Fortune's reversals in seven rhyme-royal stanzas. Between them Hammond discusses tapestry, pageantry, wall hangings, and courtly display, quoting one eight-line stanza from the 1429 Henry VI coronation banquet; she closes with a short comparison and publication note.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-hammond",
        "evidence:metadata-xml",
        "evidence:metadata-sponsler"
      ]
    },
    {
      "id": "summary:boundary",
      "type": "cataloging_note",
      "value": "Hammond's complete article spans printed pp. 10–26, but CME00085 begins at p. 13. The XML therefore preserves the two editions and later commentary while omitting the article title and introductory source discussion on pp. 10–12.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [

  "cataloging_subject": {
    "id": "work:CME00085",
    "unit_type": "edited_selection",
    "label": "Two Tapestry Poems by Lydgate: The Life of St. George and the Falls of Seven Princes (encoded selection)",
    "scope_note": "The cataloged subject is the University of Michigan CME selection from Eleanor Prescott Hammond's article, not one medieval work. CME00085 encodes printed pp. 13–26: Hammond's edition of Lydgate's 245-line Legend of St George, her intervening prose commentary with an eight-line Henry VI coronation-banquet sotelty stanza quoted from St John's College Oxford MS 57, her edition of the 49-line Of the Sodein Fal of Princes in Oure Dayes, and her closing commentary. It omits the article title and introduction on pp. 10–12. The three medieval verse items and Hammond's modern prose remain separately scoped parts."
  },
  "catalog_summary": {
    "title": "Two Tapestry Poems by Lydgate: The Life of St. George and the Falls of Seven Princes (encoded selection)",
    "author": "John Lydgate; Eleanor Prescott Hammond (commentary)",

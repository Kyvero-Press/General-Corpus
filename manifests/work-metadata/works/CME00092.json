        "evidence:repo-xml",
        "evidence:nls-thrush"
      ]
    },
    {
      "id": "summary:cataloging-boundary",
      "type": "cataloging_note",
      "value": "The five speaker headings and two final dotted lacuna rows encoded as L elements are display structure, not seven additional medieval verse lines. The source witness and NLS transcription contain 74 verse lines; DIMEV likewise reports 74 lines and says the fragment begins and ends imperfectly.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:auchinleck-fragment"
        ]
      },
      "evidence_ids": [

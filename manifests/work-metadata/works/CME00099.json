  "summaries": [
    {
      "id": "summary:abstract-en",
      "type": "abstract",
      "value": "An edited selection of 31 anonymous historical texts from two Stockholm manuscript witnesses, comprising medical and herbal recipes, healing and protective charms, blessings, prayers, and prognostics. The source texts are predominantly English with embedded Latin and French; Ferdinand Holthausen supplies German introductions, textual notes, commentary, and a postscript.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:cme00099-xml-header",
        "evidence:cme00099-preface-i",
        "evidence:cme00099-preface-ii",
        "evidence:cme00099-section-i",
        "evidence:cme00099-section-ii"
      ]
    },
    {
      "id": "summary:section-i-contents",
      "type": "contents_note",
      "value": "Twenty-eight selections from X 90 concerning childbirth and fetal death, medical and reproductive prognosis, favor magic, garlic and venom, eye disease, toothache, epilepsy, fever, rosemary, bleeding, jaundice, wounds, gout and festering flesh, pregnancy, spleen treatment, fertility, and protective ritual.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:section-i"
        ]
      },
      "evidence_ids": [
        "evidence:cme00099-section-i"
      ]
    },
    {
      "id": "summary:section-ii-contents",
      "type": "contents_note",
      "value": "Three verse charms from the manuscript dated 1597: a blood-staunching charm, a fever charm, and a spirit-expulsion or exorcism charm.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:section-ii"
        ]
      },
      "evidence_ids": [
        "evidence:cme00099-preface-ii",
        "evidence:cme00099-section-ii"
      ]
    },
    {
      "id": "summary:cataloging-scope",
      "type": "scope_note",
      "value": "The introductions mention other material in the complete manuscripts—including cosmetic recipes, longer medical poems, a plant list, and the Cadiz-expedition diary—that Holthausen did not include in this article. Those subjects are not tagged as CME00099 content.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:cme00099-preface-i",
        "evidence:cme00099-preface-ii"
      ]
    }
  ],

  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "An anonymous Middle English estates satire in which a speaker travels from Kent to London and Westminster seeking legal redress. Officials and intermediaries repeatedly demand money; after surveying the city's markets, trades, street cries, food, drink, and sharp dealing, the penniless speaker returns to Kent. The poem survives here in two substantially different sixteen-stanza recensions.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:repository-xml",
        "evidence:dimev-record",
        "evidence:mets-introduction"
      ]
    },
    {
      "id": "summary:encoded-contents",
      "type": "contents_note",
      "value": "CME00103 serializes Hammond's facing-page edition as two successive version streams: Harley 542, sixteen eight-line stanzas and 128 lines, followed by Harley 367, sixteen rhyme-royal stanzas and 112 lines. Three prose paragraphs are editorial headnotes and eighteen NOTE elements are line-specific apparatus; they are not additional medieval prose works.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:repository-xml",
        "evidence:hammond-article"
      ]
    },
    {
      "id": "summary:cataloging-boundary",
      "type": "cataloging_note",
      "value": "The two encoded texts are complete witness recensions of one poem, not two separately authored works. Hammond's 1898 editorial frame is a source-representation layer. The XML includes only the parallel texts and retained apparatus on printed pages 410-419, not the article's introduction on pages 404-409 or its page-420 list of later Harley 367 corrections.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:repository-xml",
        "evidence:hammond-article"
      ]
    },
    {
      "id": "summary:authorship-note",
      "type": "cataloging_note",
      "value": "John Lydgate is retained only as a disputed historical attribution. The Harley 367 heading and Stow's Survey associate the poem with Lydgate, but Hammond found no internal evidence for his authorship, and the current METS edition identifies the author as unknown.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:hammond-article",
        "evidence:mets-introduction"
      ]
    }
  ],

  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "An edited selection of thirty-one anonymous Middle English songs transcribed by Frederick Morgan Padelford from the Selden Carol Book component of Bodleian MS Arch. Selden B. 26. Sacred carols and devotional lyrics predominate, but the selection also includes moral, social, work, drinking, love, historical, and conduct songs. Padelford interleaves substantive collateral versions and shorter readings from English manuscript witnesses and earlier printed editions.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:padelford-edition",
        "evidence:dimev",
        "evidence:collateral-sources"
      ]
    },
    {
      "id": "summary:scope",
      "type": "scope_note",
      "value": "CME00104 begins on Padelford's printed page 86 with song 1 and ends on page 115 with song 31, his dateline, and signature. It omits the article title, introductory hand and dating discussion, source-policy statement, and thirty-one-item first-line index on pages 79-85. At the manuscript layer the selected songs run from current f. 5r through f. 33v, but intervening Latin compositions and an independent marginal poem on f. 23r are outside the selection.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:xml",
        "evidence:padelford-introduction",
        "evidence:selden-boundary",
        "evidence:dimev"
      ]
    },
    {
      "id": "summary:apparatus",
      "type": "contents_note",
      "value": "The apparatus contains twelve subordinate variant divisions attached to songs 3, 7, 8, 11, 12, 13, and 24, plus shorter comparison notes and four verse lines embedded inside prose apparatus for songs 10 and 11. Padelford uses Add MS 5665, MS Eng. poet. e. 1, Balliol MS 354, Sloane MS 2593, Fuller Maitland's Trinity Carol Roll edition, Zupitza's Jacob Ryman edition, Early Bodleian Music, and Early English Lyrics in distinct roles documented in the lineage manifest.",
      "language": "eng",
      "scope": {
        "kind": "part",
        "part_ids": [
          "part:apparatus"
        ]
      },
      "evidence_ids": [
        "evidence:xml-structure",
        "evidence:collateral-sources",
        "evidence:lineage"
      ]
    },
    {
      "id": "summary:cataloging-boundary",
      "type": "cataloging_note",
      "value": "DIMEV catalogs thirty-two English verse witnesses in Arch. Selden B. 26, while DIAMM inventories fifty-three musical compositions in the relevant music component. Neither count contradicts the thirty-one-item cataloged subject: Padelford omitted the separate f. 23r marginal quatrain, selected English songs rather than every Latin and English composition, and included the later nonmusical f. 33v song as number 31.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:selden-catalogs",
        "evidence:selden-boundary",
        "evidence:dimev"
      ]
    }
  ],

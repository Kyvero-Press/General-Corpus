  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Austin's compilation brings together 496 Middle English culinary recipes from five manuscript streams: 258 recipes in Harley 279, 182 in Harley 4016, nineteen Ashmole sauces, twenty-five Laud recipes, and twelve Douce recipes. It also prints seven principal Harley 279 menu or feast divisions and two Harley 4016 banquet records, framed by Austin's foreword, variant readings, and errata.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-1888-edition"
      ]
    },
    {
      "id": "summary:boundary",
      "type": "scope_note",
      "value": "The five streams have distinct manuscript histories and cannot be collapsed into one medieval work. Harley 279 supplies three recipe groups plus menus; Harley 4016 supplies two banquet records and a 182-recipe cookery book; the Ashmole, Laud, and Douce sections are selective extracts. Austin's exact 1888 editorial arrangement is the coherent cataloging unit.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-1888-edition",
        "evidence:metadata-witness-catalogs"
      ]
    },
    {
      "id": "summary:encoding",
      "type": "cataloging_note",
      "value": "The XML has ten DIV1, twenty-one DIV2, eleven DIV3, 538 P, 875 ITEM, fifty-three LIST, eight L, and 137 PB elements. Those raw structural counts describe the encoding, not 875 independent intellectual works. The eight verse lines belong to Austin's modern foreword.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml-audit"
      ]
    }
  ],
  "extent": {
    "numbered_items": 505,
    "sections": 21,
    "prose_only_items": 505,
    "verse_only_items": 0,
    "mixed_items": 0,
    "verse_groups": 0,
    "verse_lines": 0,
    "description": "The intellectual-work count records 505 units: 496 recipes plus nine principal feast or banquet units, all prose. The 496 recipes comprise 153 potages, 64 leche metys, 41 bake metis, 182 Harley 4016 recipes, 19 Ashmole sauces, 25 Laud recipes, and 12 Douce recipes. 'Sections' reports the XML's 21 DIV2 elements for reproducibility, while 875 ITEM elements chiefly encode recipe tables of contents and menu dishes rather than 875 independent works. Eight XML L elements in Austin's modern foreword are excluded from the medieval-work verse totals.",
    "evidence_ids": [
      "evidence:metadata-xml-audit",
      "evidence:metadata-1888-edition"
    ]
  },

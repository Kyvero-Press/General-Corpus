  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Julian of Norwich's extended prose account of sixteen revelations received during severe illness in May 1373 and contemplated over subsequent decades. The Long Text develops a theology of divine love through meditation on Christ's Passion, sin and salvation, prayer, the Trinity, spiritual motherhood, suffering, hope, and the assurance that all shall be well.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:julian-xml",
        "evidence:julian-sloane2499",
        "evidence:julian-mets"
      ]
    },
    {
      "id": "summary:scope",
      "type": "scope_note",
      "value": "This record describes the Long Text, not the shorter account now called A Vision Showed to a Devout Woman. The repository XML follows Glasscoe's 1976 edition based on the seventeenth-century Sloane 2499 copy; that late witness date is not the work's composition date.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:julian-xml",
        "evidence:julian-sloane2499",
        "evidence:julian-glasscoe-catalog"
      ]
    }
  ],

  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "A grieving dreamer falls asleep in a garden where his lost pearl was buried and enters a jeweled visionary landscape. Across a river he meets the Pearl Maiden, who corrects his earthly assumptions about loss, merit, innocence, grace, and heavenly reward. She reveals the New Jerusalem and joins the Lamb's procession. When the dreamer tries to cross the river, he awakens and ends by submitting his pearl and himself to God's will.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:linked-pearl-xml-content",
        "evidence:oxford-gawain-poet",
        "evidence:liverpool-pearl-description"
      ]
    },
    {
      "id": "summary:cataloging-note",
      "type": "cataloging_note",
      "value": "Pearl survives uniquely in British Library Cotton MS Nero A X/2 with Cleanness, Patience, and Sir Gawain and the Green Knight. The repository text descends through E. V. Gordon's 1953 scholarly edition and a U-M/OTA electronic encoding that omits the edition's preface, contents, abbreviations, introduction, bibliography, notes, and appendixes.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:bl-cotton-nero-a-x-2",
        "evidence:linked-pearl-xml-header",
        "evidence:umich-pearl-item"
      ]
    }
  ],

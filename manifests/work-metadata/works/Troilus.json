  "summaries": [
    {"id": "summary:abstract", "type": "abstract", "value": "A five-book Middle English narrative poem recounting Troilus's love for Criseyde during the Trojan War, their union through Pandarus, Criseyde's exchange to the Greek camp and relationship with Diomede, and Troilus's death and final vision beyond earthly mutability. Chaucer transforms Boccaccio's Il Filostrato through sustained reflection on love, agency, Fortune, providence, and authorship.", "language": "eng", "scope": {"kind": "whole"}, "evidence_ids": ["evidence:troilus-xml", "evidence:troilus-windeatt", "evidence:troilus-scholarly"]},
    {"id": "summary:scope", "type": "scope_note", "value": "This record describes Chaucer's poem. The 1984 printed source also contains Italian parallel text and modern editorial matter that the electronic edition expressly omits.", "language": "eng", "scope": {"kind": "whole"}, "evidence_ids": ["evidence:troilus-xml", "evidence:troilus-windeatt"]}
  ],

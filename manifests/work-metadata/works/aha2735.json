  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "Robert Mannyng's Handlyng Synne is a long Middle English penitential poem begun in 1303 for a lay audience. Translating and extensively adapting William of Waddington's Anglo-French Manuel des péchés, it organizes moral and pastoral instruction around the Ten Commandments, seven deadly sins, sacrilege, seven sacraments, and confession, repeatedly using memorable exempla to expose sin and promote amendment.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-part1",
        "evidence:metadata-part2"
      ]
    },
    {
      "id": "summary:contents",
      "type": "contents_note",
      "value": "Prologue; the Ten Commandments; the seven deadly sins; sacrilege; the seven sacraments; and a final confession sequence comprising a prologue, twelve points, eight graces, and properties of shrift.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-computation"
      ]
    },
    {
      "id": "summary:cataloging-boundary",
      "type": "scope_note",
      "value": "The U-M XML encodes Furnivall's English text and parallel French source portions within a 1901–1903 edition carrier, but this record describes Mannyng's English work. The parallel Manuel des péchés is modeled as a related source work and in lineage, not merged into the target's language or extent.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-xml",
        "evidence:metadata-part1",
        "evidence:metadata-part2"
      ]
    }
  ],

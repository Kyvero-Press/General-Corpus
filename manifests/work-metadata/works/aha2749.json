  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "The treatise identifies Antichrist first in general moral terms and then in the pope, prelates, and religious orders; distinguishes the true church, the material mixed church, and the devil's church; teaches discernment, faith, hope, charity, and joy under persecution; and applies the Ten Commandments to contemporary religious and social abuses. Middle English exposition is repeatedly grounded in Latin Scripture and patristic, scholastic, and canon-law authorities.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-repo-xml",
        "evidence:metadata-swinburn-1917",
        "evidence:metadata-dean-1996"
      ]
    },
    {
      "id": "summary:cataloging",
      "type": "cataloging_note",
      "value": "The work is prose-only. Verse-line markup in AHA2749 belongs to quotations in Swinburn's appendix and notes, not to the medieval treatise. The XML reproduces Swinburn's complete edited text but not his glossary, and its legacy Wycliffe author field records superseded attribution history.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:metadata-repo-xml",
        "evidence:metadata-xml-structure",
        "evidence:metadata-swinburn-1917"
      ]
    }
  ],

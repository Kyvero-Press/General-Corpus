  "summaries": [
    {
      "id": "summary:abstract",
      "type": "abstract",
      "value": "A seven-poem edited selection of Middle English religious verse associated with William of Shoreham, vicar of Chart Sutton in Kent. It joins catechetical and pastoral teaching on the sacraments, Ten Commandments, deadly sins, and Christian doctrine with an Hours poem and two Marian works. The sixth poem’s authorship or source remains disputed because its closing notice invokes Robert Grosseteste; the seventh survives incompletely. The repository XML is a 2006 uncorrected OCR of Konrath’s 1902 edition, not a direct manuscript transcription.",
      "language": "eng",
      "scope": {
        "kind": "whole"
      },
      "evidence_ids": [
        "evidence:repo-xml",
        "evidence:konrath-1902",
        "evidence:dimev",
        "evidence:mets-part-6"
      ]
    }
  ],

{
  "name": "@kyvero-press/general-corpus-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-only",
  "scripts": {
    "catalog": "python3 ../scripts/build-corpus-viewer-catalog.py --output-root build/corpus-viewer/public",
    "catalog:assets": "python3 ../scripts/build-corpus-viewer-catalog.py --output-root build/corpus-viewer/public --copy-pdfs",
    "dev": "npm run catalog && vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run catalog && npm run typecheck && vite build && python3 ../scripts/build-corpus-viewer-catalog.py --output-root build/corpus-viewer/site --copy-pdfs --require-pdfs --publication-inventory manifests/publication-set/viewer-default.json",
    "build:allow-missing": "npm run catalog && npm run typecheck && vite build && python3 ../scripts/build-corpus-viewer-catalog.py --output-root build/corpus-viewer/site --copy-pdfs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
